# LLM Provider Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Prisma AIRS Guardrails (optional - demo works without these)
PRISMA_AIRS_API_KEY=
PRISMA_AIRS_PROFILE_NAME=chatbot

# Portkey Gateway URL (default for local Docker gateway)
PORTKEY_GATEWAY_URL=http://localhost:8787/v1
